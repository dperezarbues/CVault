// ── Colors ────────────────────────────────────────────────────────────────────
#let c-ink   = rgb("#111111")  // name, titles
#let c-body  = rgb("#333333")  // body text
#let c-muted = rgb("#666666")  // metadata, company, period
#let c-light = rgb("#999999")  // section labels, pills, cert footnotes
#let c-rule  = rgb("#dddddd")  // dividers, pill borders
#let c-link  = rgb("#1a56db")  // hyperlinks

// ── Type scale (6 sizes) ─────────────────────────────────────────────────────
#let fs-xl    = 17pt   // document name
#let fs-lg    = 10pt   // headline
#let fs-title = 9.5pt  // entry titles (job, education, project)
#let fs-body  = 8.5pt  // body text, bullets, descriptions
#let fs-meta  = 8pt    // contact info, company, period, cert names
#let fs-label = 7.5pt  // section headers, status badges, cert footnotes
#let fs-micro = 6.5pt  // skill group labels, pill text

// ── Spacing scale (4 levels) ─────────────────────────────────────────────────
#let sp-lg   = 0.55em  // between major entries (jobs, projects)
#let sp-md   = 0.35em  // between minor entries (certs, awards)
#let sp-sm   = 0.1em   // between tight items (bullets)
#let sp-xs   = 3pt     // within an entry (title→meta, meta→bullets)

// ── Page ─────────────────────────────────────────────────────────────────────
#let font-family   = "New Computer Modern"
#let page-paper    = "a4"
#let page-margin-x = 1.4cm
#let page-margin-y = 1.1cm
#let par-leading   = 0.68em
#let block-spacing = 0.45em

// ── Section header style ──────────────────────────────────────────────────────
#let section-pre      = 0.5em   // space above the section title
#let section-post     = 0.2em   // space below the rule, before content
#let section-tracking = 1.5pt
#let section-fill     = rgb("#444444")
#let rule-weight      = 0.6pt
#let rule-color       = rgb("#bbbbbb")

// ── Skills ────────────────────────────────────────────────────────────────────
#let skills-gutter          = 1.2cm
#let skills-label-tracking  = 0.8pt
